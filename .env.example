# PressTech Frontend Environment Variables
# Copy to .env.local for local dev

# ============================================
# LOCAL DEVELOPMENT
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCKS=false

# Set to true only if you want MSW mock API (no real backend):
# NEXT_PUBLIC_USE_MOCKS=true

# ============================================
# PRODUCTION (Vercel: presstech.vercel.app)
# Add these in Vercel → Project → Settings → Environment Variables
# ============================================
# NEXT_PUBLIC_API_URL=https://presstech.atechleb.com
#
# Do NOT set NEXT_PUBLIC_USE_MOCKS in production.
